    <Template Key="c1a2b3c4-1010-0010-0010-000000000022">lgServicePage</Template>
  </Info>
  <Properties>
    <summary>
      <Value><![CDATA[A guide to which materials go in each bin so we can recycle as much as possible.]]></Value>
    </summary>
    <main>
      <Value><![CDATA[<h2 class="govuk-heading-m">Green bin (recycling)</h2><ul class="govuk-list govuk-list--bullet"><li>Paper, cardboard, and clean envelopes</li><li>Plastic bottles, pots, tubs, and trays (rinsed)</li><li>Tins and aerosol cans</li><li>Glass bottles and jars</li></ul><h2 class="govuk-heading-m">Black bin (household waste)</h2><ul class="govuk-list govuk-list--bullet"><li>Anything that can't be recycled</li><li>Nappies, sanitary products, and pet waste</li><li>Polystyrene and bubble wrap</li></ul><h2 class="govuk-heading-m">Brown bin (garden waste)</h2><ul class="govuk-list govuk-list--bullet"><li>Grass cuttings, leaves, and small branches</li><li>Plants, flowers, and weeds</li></ul><h2 class="govuk-heading-m">Food caddy</h2><ul class="govuk-list govuk-list--bullet"><li>All cooked and uncooked food, including bones, peelings, and tea bags</li></ul>]]></Value>
    </main>
  </Properties>
</Content>

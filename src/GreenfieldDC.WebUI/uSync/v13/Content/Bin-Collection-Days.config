    <Template Key="c1a2b3c4-1010-0010-0010-000000000022">lgServicePage</Template>
  </Info>
  <Properties>
    <summary>
      <Value><![CDATA[Check when your household waste, recycling, garden waste, and food waste will be collected.]]></Value>
    </summary>
    <main>
      <Value><![CDATA[<p class="govuk-body">Enter your postcode in the search above to find your collection days. Collections happen on a two-week rolling cycle and may shift by one day on bank holiday weeks.</p><h2 class="govuk-heading-m">What we collect</h2><ul class="govuk-list govuk-list--bullet"><li>Household waste (black bin) — fortnightly</li><li>Recycling (green bin) — fortnightly, alternating with household waste</li><li>Garden waste (brown bin) — fortnightly, March to November</li><li>Food waste (small caddy) — weekly</li></ul><p class="govuk-body">Please put your bins out by 6.30am on your collection day and bring them back in by the end of the day.</p>]]></Value>
    </main>
  </Properties>
</Content>

    <Template Key="c1a2b3c4-1010-0010-0010-000000000041">lgGuidePage</Template>
  </Info>
  <Properties>
    <main>
      <Value><![CDATA[<p class="govuk-body">You may be entitled to a reduction on your council tax bill if you live alone, are a student, are on a low income, or fall into one of several other categories.</p><p class="govuk-body">Single person discount is the most common — it gives you 25% off if you're the only adult living in your home. You can apply online and you'll need to tell us if your circumstances change.</p>]]></Value>
    </main>
  </Properties>
</Content>

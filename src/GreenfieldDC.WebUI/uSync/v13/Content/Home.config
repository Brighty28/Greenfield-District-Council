  <Properties>
    <introText>
      <Value><![CDATA[Welcome to Greenfield District Council — your local council for the Greenfield district.]]></Value>
    </introText>
    <summary>
      <Value><![CDATA[Greenfield District Council serves around 90,000 residents and businesses across the Greenfield district. Find council services, news, and how to get in touch.]]></Value>
    </summary>
    <main>
      <Value><![CDATA[<p class="govuk-body">Use the service areas below to find what you need — from bin collections to council tax, planning to parking. If you can't find what you're looking for, you can also <a class="govuk-link" href="#">contact us directly</a>.</p>]]></Value>
    </main>
  </Properties>

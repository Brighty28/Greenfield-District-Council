    <Template Key="c1a2b3c4-1010-0010-0010-000000000041">lgGuidePage</Template>
  </Info>
  <Properties>
    <main>
      <Value><![CDATA[<p class="govuk-body">Direct debit is the easiest way to pay your council tax. Payments are spread over 10 or 12 monthly instalments and come straight from your bank account, so you'll never miss a payment.</p><p class="govuk-body">You can choose a payment date of the 1st, 15th, or 25th of the month. To set up a direct debit, you'll need your council tax account number and your bank details.</p>]]></Value>
    </main>
  </Properties>
</Content>

  <Properties>
    <main>
      <Value><![CDATA[<p class="govuk-body">Pay your council tax online with a debit or credit card. Online payments are processed through our secure payment provider and usually clear within 3 working days.</p><p class="govuk-body">You'll need your council tax account number, found at the top right of your bill, and your card details.</p>]]></Value>
    </main>
  </Properties>

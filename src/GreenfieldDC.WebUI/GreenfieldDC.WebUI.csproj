<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>GreenfieldDC.WebUI</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Umbraco CMS core (required by all Umbraco sites) -->
    <PackageReference Include="Umbraco.Cms" Version="13.12.1" />
    <!-- All Phase 1 LocalGov modules via the meta-package -->
    <PackageReference Include="LocalGov.Umbraco" Version="1.0.3" />
    <!-- SQLite for local/demo use — swap for SQL Server in production -->
    <PackageReference Include="Umbraco.Cms.Persistence.Sqlite" Version="13.12.1" />
  </ItemGroup>

</Project>

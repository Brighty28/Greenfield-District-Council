{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Umbraco": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SQLite"
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "SiteName": "Greenfield District Council",
        "UseHttps": false
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportAtStartup": "All",
      "ExportAtStartup": "None",
      "ExportOnSave": "None",
      "UIEnabledGroups": "All"
    }
  }
}

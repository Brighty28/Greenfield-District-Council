# Build outputs
bin/
obj/

# IDE
.vs/
.vscode/
*.user
*.suo
.idea/

# Umbraco runtime data (not source)
src/*/umbraco/Data/
src/*/umbraco/Logs/
src/*/umbraco/mediacache/
src/*/App_Data/
src/*/Logs/
src/*/media/

# uSync media is environment-specific (binary uploads). Content is committed
# below as the canonical demo seed — uSync re-imports it on every start.
src/*/uSync/v13/Media/

# SQLite database
*.sqlite.db
*.sqlite.db-shm
*.sqlite.db-wal

# Sensitive config
appsettings.Production.json
appsettings.Staging.json

# NuGet
*.nupkg

# OS
.DS_Store
Thumbs.db

# Smidge
/src/*/Smidge/Cache/

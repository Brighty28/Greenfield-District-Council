<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      For local development before NuGet publish:
      run 'dotnet pack' in the sibling Local-Gov-Umbraco repo first.
      Assumes repos cloned side-by-side under the same parent folder:
        ..\Greenfield-District-Council
        ..\Local-Gov-Umbraco
      Both relative paths below are listed so the feed is found whether
      the package repo was cloned with the GitHub-default hyphenated name
      (Local-Gov-Umbraco) or renamed to dotted (LocalGov.Umbraco).
    -->
    <add key="localgov-local" value="../Local-Gov-Umbraco/nupkgs" />
    <add key="localgov-local-alt" value="../LocalGov.Umbraco/nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="3CDigital" value="https://pkgs.dev.azure.com/3CDigital/_packaging/3CDigital/nuget/v3/index.json" />
  </packageSources>
</configuration>

<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      Primary feed: 3CDigital Azure Artifacts (private).
      Authentication: developers should run `dotnet nuget add source` once with a
      Personal Access Token (Packaging > Read), or use Visual Studio's signed-in
      Azure account. CI agents authenticate via the NuGetAuthenticate@1 task.
    -->
    <add key="3cdigital" value="https://pkgs.dev.azure.com/3CDigital/Digital%20Project/_packaging/3CDigital/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>

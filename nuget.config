<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      For local development before NuGet publish:
      run 'dotnet pack' in the sibling LocalGov.Umbraco repo first.
      Assumes repos cloned side-by-side: ../LocalGov.Umbraco/nupkgs
    -->
    <add key="localgov-local" value="../LocalGov.Umbraco/nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
